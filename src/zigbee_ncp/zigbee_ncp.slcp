project_name: zigbee_ncp
label: Zigbee - NCP
package: zigbee
category: Zigbee Application
quality: production
description: Zigbee NCP firmware optimized for Zigbee2MQTT use. Derived from the `zigbee_ncp_uart_hw` example Simplicity SDK project.
author: Nerivec

component:
  - id: sl_main
  - id: iostream_usart
    instance:
      - vcom
    condition:
      - device_generic_family_efr32xg21
  - id: iostream_eusart
    instance:
      - vcom
    condition:
      - device_has_eusart
  - id: zigbee_debug_print
  - id: iostream_vuart
  - id: common_token_manager
  - id: zigbee_pro_stack
  - id: zigbee_source_route
  - id: zigbee_gp
  - id: zigbee_r22_support
  - id: zigbee_security_link_keys
  - id: zigbee_zll
  - id: zigbee_system_common
  - id: zigbee_ncp_uart_hardware
  - id: zigbee_debug_basic
  - id: zigbee_debug_extended
  - id: clock_manager
  - id: toolchain_gcc_lto
  # custom from zigbee_ncp_uart_hw
  - id: zigbee_token_interface
  - id: zigbee_mfglib
  - id: rail_util_rssi

define:
  # - name: SL_ZIGBEE_CUSTOM_MAC_FILTER_TABLE_SIZE
  #   value: 15
  - name: SL_ZIGBEE_MULTICAST_TABLE_SIZE
    value: 26
  - name: SL_ZIGBEE_ROUTE_TABLE_SIZE
    value: 16
  ## xg21
  - name: SL_ZIGBEE_DISCOVERY_TABLE_SIZE
    value: 8
    condition: ["device_generic_family_efr32xg21"]
  ## xg24
  - name: SL_ZIGBEE_DISCOVERY_TABLE_SIZE
    value: 32
    condition: ["device_generic_family_efr32xg24"]
  - name: SL_ZIGBEE_ROUTE_TABLE_SIZE
    value: 200
    condition: ["device_generic_family_efr32xg24"]
  - name: SL_ZIGBEE_RETRY_QUEUE_SIZE
    value: 32
    condition: ["device_generic_family_efr32xg24"]
   ## xg26
  - name: SL_ZIGBEE_DISCOVERY_TABLE_SIZE
    value: 16
    condition: ["device_generic_family_efr32xg26"]

configuration:
  - name: SL_BOARD_ENABLE_VCOM
    value: 1
  - name: SL_IOSTREAM_USART_VCOM_FLOW_CONTROL_TYPE
    value: usartHwFlowControlCtsAndRts
    condition:
      - iostream_usart
  - name: SL_IOSTREAM_EUSART_VCOM_FLOW_CONTROL_TYPE
    value: SL_IOSTREAM_EUSART_UART_FLOW_CTRL_CTS_RTS
    condition:
      - iostream_eusart
  - name: SL_CLI_MAX_INPUT_ARGUMENTS
    value: 16
  - name: SL_ZIGBEE_BINDING_TABLE_SIZE
    value: 32
  - name: SL_ZIGBEE_MAX_END_DEVICE_CHILDREN
    value: 32
  - name: SL_ZIGBEE_PACKET_BUFFER_HEAP_SIZE
    value: SL_ZIGBEE_HUGE_PACKET_BUFFER_HEAP
  # - name: EMBER_AF_PLUGIN_ZIGBEE_PRO_STACK_CHILD_TABLE_SIZE
  #   value: 32
  # - name: SL_ZIGBEE_KEY_TABLE_SIZE
  #   value: 20
  - name: SL_CLI_EXAMPLE_IOSTREAM_HANDLE
    value: sl_iostream_vuart_handle
  - name: NVM3_DEFAULT_NVM_SIZE
    value: 32768
    condition:
      - device_series_2
  # If using zigbee_secure_key_storage we do not need to support backwards
  # compatibility because we have never deployed images with keys in PSA
  # As a result, these lines end up saving some code space
  - name: SL_PSA_ITS_SUPPORT_V1_DRIVER
    value: 0
  - name: SL_PSA_ITS_SUPPORT_V2_DRIVER
    value: 0
  - name: SL_PSA_ITS_SUPPORT_V3_DRIVER
    value: 1
  - name: SL_STACK_SIZE
    value: 4096
    condition:
      - cmsis_rtos2
  - name: SL_ZIGBEE_STACK_RTOS_TASK_STACK_SIZE
    value: 4096
    condition:
      - cmsis_rtos2
  # custom from zigbee_ncp_uart_hw
  - name: SL_IOSTREAM_USART_VCOM_RX_BUFFER_SIZE
    value: 128
    condition:
      - iostream_usart
  - name: SL_IOSTREAM_EUSART_VCOM_RX_BUFFER_SIZE
    value: 128
    condition:
      - iostream_eusart
  - name: SL_ZIGBEE_BROADCAST_TABLE_SIZE
    value: 100
  - name: SL_ZIGBEE_NEIGHBOR_TABLE_SIZE
    value: 26
  - name: SL_ZIGBEE_BINDING_TABLE_SIZE
    value: 32
  - name: SL_ZIGBEE_KEY_TABLE_SIZE
    value: 1
  ## xg21
  - name: SL_ZIGBEE_SOURCE_ROUTE_TABLE_SIZE
    value: 200
    condition: ["device_generic_family_efr32xg21"]
  - name: SL_ZIGBEE_ADDRESS_TABLE_SIZE
    value: 32
    condition: ["device_generic_family_efr32xg21"]
  - name: SL_ZIGBEE_APS_UNICAST_MESSAGE_COUNT
    value: 64
    condition: ["device_generic_family_efr32xg21"]
  - name: SL_ZIGBEE_MAX_END_DEVICE_CHILDREN
    value: 32
    condition: ["device_generic_family_efr32xg21"]
  ## xg24
  - name: SL_ZIGBEE_SOURCE_ROUTE_TABLE_SIZE
    value: 254
    condition: ["device_generic_family_efr32xg24"]
  - name: SL_ZIGBEE_MAX_NEIGHBOR_TABLE_SIZE
    value: 26
    condition: ["device_generic_family_efr32xg24"] 
  - name: SL_ZIGBEE_ADDRESS_TABLE_SIZE
    value: 250
    condition: ["device_generic_family_efr32xg24"]
  - name: SL_ZIGBEE_APS_UNICAST_MESSAGE_COUNT
    value: 128
    condition: ["device_generic_family_efr32xg24"]
  - name: SL_ZIGBEE_MAX_END_DEVICE_CHILDREN
    value: 64
    condition: ["device_generic_family_efr32xg24"]
  - name: SL_ZIGBEE_APS_DUPLICATE_REJECTION_MAX_ENTRIES
    value: 96
    condition: ["device_generic_family_efr32xg24"]
  - name: SL_ZIGBEE_PAN_ID_CONFLICT_REPORT_THRESHOLD
    value: 3
    condition: ["device_generic_family_efr32xg24"]
  
  ## xg26
  - name: SL_ZIGBEE_SOURCE_ROUTE_TABLE_SIZE
    value: 254
    condition: ["device_generic_family_efr32xg26"]
  - name: SL_ZIGBEE_ADDRESS_TABLE_SIZE
    value: 64
    condition: ["device_generic_family_efr32xg26"]
  - name: SL_ZIGBEE_APS_UNICAST_MESSAGE_COUNT
    value: 128
    condition: ["device_generic_family_efr32xg26"]
  - name: SL_ZIGBEE_MAX_END_DEVICE_CHILDREN
    value: 64
    condition: ["device_generic_family_efr32xg26"]
  - name: SL_ZIGBEE_APS_DUPLICATE_REJECTION_MAX_ENTRIES
    value: 64
    condition: ["device_generic_family_efr32xg26"]

source:
  - path: main.c
    unless: [cmsis_rtos2]
  - path: app.c

filter:
  - name: Wireless Technology
    value: [Zigbee]
  - name: Device Type
    value: [NCP]
  - name: Project Difficulty
    value: [Advanced]
